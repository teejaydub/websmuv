ssh:
	cd websmuv && make ssh

nginx-start:
	cd websmuv && make nginx-start

nginx-stop:
	cd websmuv && make nginx-stop

nginx-maintenance:
	cd websmuv && make nginx-configure nginx-enable-maintenance nginx-disable-redirect80 nginx-reload nginx-status

nginx-normal:
	cd websmuv && make nginx-configure nginx-disable-maintenance nginx-enable-redirect80 nginx-reload nginx-status

nginx-follow-log:
	cd websmuv && make nginx-follow-log

nginx-log:
	cd websmuv && make nginx-log


websmuv-update-start:
	cd websmuv && make update-start

websmuv-update-middle:
	cd websmuv && make update-middle

websmuv-update-end:
	cd websmuv && make update-end
	